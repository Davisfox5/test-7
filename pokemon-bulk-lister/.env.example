# eBay developer credentials (https://developer.ebay.com/)
# Create an app at developer.ebay.com -> My Account -> Application Keysets.
# Use the *Production* App ID (Client ID) and Cert ID (Client Secret).
# Marketplace Insights API requires applying for access on the same portal.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_MARKETPLACE_ID=EBAY_US
EBAY_ENV=production  # production | sandbox

# pokemontcg.io — free tier needs no key, but a key raises rate limits.
# Get one at https://dev.pokemontcg.io/
POKEMONTCG_API_KEY=

# Cloudinary (reuse First XI Fitness creds)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=pokemon-bulk

# --- Claude vision identification ---
# Powers "Identify all (AI)" / "AI identify" in the web UI. Get a key at
# https://platform.claude.com/ (or run `ant auth login` and leave this blank).
ANTHROPIC_API_KEY=
# Identification is constrained extraction — Haiku handles most cards.
VISION_MODEL=claude-haiku-4-5
# Page-level results below this confidence get a per-crop retry call.
VISION_RETRY_CONFIDENCE=0.6

# EUR->USD rate for Cardmarket trend price conversion.
# Cardmarket prices come from pokemontcg.io in EUR; pricing aggregation needs USD.
EUR_USD_RATE=1.08

# --- Terapeak (eBay Seller Hub) headless scraping ---
# Optional 4th pricing source: 365-day eBay sold history via headless browser
# against the Seller Hub Terapeak Research UI. Requires an eBay account with
# Seller Hub access; first run is headful so you can log in once.
ENABLE_TERAPEAK=0
TERAPEAK_HEADLESS=1            # 1 to run headless after first login, 0 for headful
TERAPEAK_STATE_PATH=output/cache/terapeak_state.json
TERAPEAK_MIN_DELAY=4           # seconds between searches
TERAPEAK_MAX_JITTER=4          # added random seconds 0..jitter
# Optional proxy rotation, comma-separated. Examples:
#   http://user:pass@host1:port,http://user:pass@host2:port
TERAPEAK_PROXIES=

# --- eBay listing (Sell API) ---
# Publishing live listings needs a *user* OAuth token (authorization-code grant),
# separate from the client-credentials token used for pricing. Create a RuName
# under developer.ebay.com -> User Tokens -> "Get a Token from eBay via Your
# Application", set its accepted URL, and paste the RuName value here. Then run
# `python -m webapp.setup_ebay` once to authorize.
EBAY_REDIRECT_URI=                 # your RuName (NOT a raw URL)
EBAY_USER_TOKEN_PATH=output/cache/ebay_user_token.json
# publishOffer requires three business policies + an inventory location. We
# auto-resolve the account's first of each; pin specific IDs here to override.
EBAY_FULFILLMENT_POLICY_ID=
EBAY_PAYMENT_POLICY_ID=
EBAY_RETURN_POLICY_ID=
EBAY_MERCHANT_LOCATION_KEY=
EBAY_LOCATION_POSTAL_CODE=10001    # only used if we have to create a location
EBAY_LOCATION_COUNTRY=US

# --- TCGPlayer / Whatnot headless CSV upload (optional) ---
# No public listing API for typical sellers, so we drive the Seller Portal in a
# headless browser and submit the generated CSV. ⚠️ Against their Terms and
# fragile — use a personal/secondary account at your own risk. Run
# `python -m webapp.setup_portal --site tcgplayer|whatnot` once to save a login.
TCGPLAYER_STATE_PATH=output/cache/tcgplayer_state.json
TCGPLAYER_HEADLESS=1
# TCGPLAYER_UPLOAD_URL=            # override if the portal layout moves
WHATNOT_STATE_PATH=output/cache/whatnot_state.json
WHATNOT_HEADLESS=1
# WHATNOT_UPLOAD_URL=

# Optional: override default paths
INPUT_DIR=input/grids
OUTPUT_DIR=output
